#!/bin/bash

# ============================================
# YouTube 万能下载器 v7.1
# 功能：自动检测依赖、灵活选择认证方式、下载最高画质+字幕+封面
# 新增：自动检测并安装缺失的 Python 包
# ============================================

# 设置颜色输出
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# 获取脚本所在目录
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# 打印带颜色的信息
info() { echo -e "${GREEN}[信息]${NC} $1"; }
warn() { echo -e "${YELLOW}[警告]${NC} $1"; }
error() { echo -e "${RED}[错误]${NC} $1"; }
step() { echo -e "\n${BLUE}>>>${NC} ${BLUE}$1${NC}"; }

# 清屏并显示标题
clear
echo -e "${GREEN}========================================${NC}"
echo -e "${GREEN}      YouTube 万能下载器 v7.1          ${NC}"
echo -e "${GREEN}========================================${NC}"
echo ""

# ============================================
# 辅助函数：自动安装 Python 包
# ============================================
install_pip_package() {
    local package=$1
    local import_name=${2:-$1}
    
    # 检查包是否已安装
    if python3 -c "import $import_name" 2>/dev/null; then
        info "✓ Python 包 $package 已安装"
        return 0
    fi
    
    warn "未找到 Python 包: $package"
    read -p "是否自动安装 $package？(y/n): " install_it
    if [[ "$install_it" =~ ^[Yy]$ ]]; then
        info "正在安装 $package..."
        pip install "$package" --break-system-packages 2>/dev/null
        if python3 -c "import $import_name" 2>/dev/null; then
            info "✓ $package 安装成功"
            return 0
        else
            warn "$package 安装失败，可能影响部分功能"
            return 1
        fi
    else
        warn "跳过安装 $package，相关功能可能受限"
        return 1
    fi
}

# ============================================
# 第一步：检测并安装 pip（如果需要）
# ============================================
step "0/7 检测 Python 环境"

if ! command -v python3 &> /dev/null; then
    error "未找到 Python3，请先安装 Python3"
    exit 1
fi

if ! command -v pip &> /dev/null; then
    warn "未找到 pip"
    read -p "是否安装 pip？(y/n): " install_pip
    if [[ "$install_pip" =~ ^[Yy]$ ]]; then
        sudo apt update && sudo apt install python3-pip -y
        info "✓ pip 安装完成"
    else
        error "无法继续，请手动安装 pip"
        exit 1
    fi
fi

info "Python3 已就绪"

# ============================================
# 第二步：检测并安装必要依赖
# ============================================
step "1/7 检测系统依赖"

# 检测 yt-dlp
YT_DLP_CMD=""
if command -v yt-dlp &> /dev/null; then
    YT_DLP_CMD="yt-dlp"
    info "✓ yt-dlp 已安装"
else
    warn "未找到 yt-dlp"
    read -p "是否自动安装 yt-dlp？(y/n): " install_yt
    if [[ "$install_yt" =~ ^[Yy]$ ]]; then
        info "正在安装 yt-dlp..."
        pip install -U "yt-dlp[default]" --break-system-packages 2>/dev/null
        if [ -f "$HOME/.local/bin/yt-dlp" ]; then
            YT_DLP_CMD="$HOME/.local/bin/yt-dlp"
            export PATH="$HOME/.local/bin:$PATH"
            info "✓ yt-dlp 安装成功"
        elif command -v yt-dlp &> /dev/null; then
            YT_DLP_CMD="yt-dlp"
            info "✓ yt-dlp 安装成功"
        else
            error "yt-dlp 安装失败，请手动安装"
            exit 1
        fi
    else
        error "无法继续，请手动安装 yt-dlp"
        exit 1
    fi
fi

# 检测 ffmpeg
if ! command -v ffmpeg &> /dev/null; then
    warn "未找到 ffmpeg（字幕转换需要）"
    read -p "是否安装 ffmpeg？(y/n): " install_ff
    if [[ "$install_ff" =~ ^[Yy]$ ]]; then
        sudo apt update && sudo apt install ffmpeg -y
        info "✓ ffmpeg 安装完成"
    else
        warn "跳过 ffmpeg 安装，将无法转换字幕格式"
    fi
fi

# 检测 Deno (JavaScript 运行时，YouTube 需要)
if ! command -v deno &> /dev/null; then
    warn "未找到 Deno（YouTube 签名解密需要）"
    read -p "是否安装 Deno？(y/n): " install_deno
    if [[ "$install_deno" =~ ^[Yy]$ ]]; then
        info "正在安装 Deno..."
        curl -fsSL https://deno.land/install.sh | sh
        export PATH="$HOME/.deno/bin:$PATH"
        echo 'export PATH="$HOME/.deno/bin:$PATH"' >> ~/.bashrc
        info "✓ Deno 安装完成（请重启终端后生效）"
    else
        warn "跳过 Deno 安装，下载可能会失败"
    fi
fi

# ============================================
# 第三步：检测并安装 Python 依赖包
# ============================================
step "2/7 检测 Python 依赖包"

# 安装必要的 Python 包
install_pip_package "certifi" "certifi"
install_pip_package "requests" "requests"
install_pip_package "urllib3" "urllib3"

# 如果选择 Chrome Cookie，需要 secretstorage
read -p "是否使用 Chrome Cookie？(y/n，如选是将安装 secretstorage): " use_chrome
if [[ "$use_chrome" =~ ^[Yy]$ ]]; then
    install_pip_package "secretstorage" "secretstorage"
fi

# ============================================
# 第四步：检查 yt-dlp 版本
# ============================================
step "3/7 检查 yt-dlp 版本"
YT_VERSION=$($YT_DLP_CMD --version 2>/dev/null)
info "当前版本: $YT_VERSION"

# 检查是否为旧版本（2024年之前）
if [[ "$YT_VERSION" < "2025" ]]; then
    warn "版本较旧，建议更新"
    read -p "是否更新到最新版？(y/n): " update_yt
    if [[ "$update_yt" =~ ^[Yy]$ ]]; then
        pip install -U "yt-dlp[default]" --break-system-packages 2>/dev/null
        YT_VERSION=$($YT_DLP_CMD --version)
        info "✓ 已更新到 $YT_VERSION"
    fi
fi

# ============================================
# 第五步：选择保存目录
# ============================================
step "4/7 选择保存目录"
echo "当前目录: $SCRIPT_DIR"
read -p "是否使用当前目录？(y/n): " use_current
if [[ "$use_current" =~ ^[Yy]$ ]]; then
    SAVE_DIR="$SCRIPT_DIR"
else
    read -p "请输入保存路径: " SAVE_DIR
    if [ ! -d "$SAVE_DIR" ]; then
        mkdir -p "$SAVE_DIR"
        info "已创建目录: $SAVE_DIR"
    fi
fi
cd "$SAVE_DIR"
info "文件将保存到: $SAVE_DIR"

# ============================================
# 第六步：选择认证方式
# ============================================
step "5/7 选择认证方式（用于访问受限内容）"
echo "1) 使用 cookies.txt 文件（最稳定）"
echo "2) 从 Firefox 导入 Cookie（推荐）"
echo "3) 从 Chrome 导入 Cookie（需安装依赖）"
echo "4) 跳过认证（仅可下载公开视频）"
read -p "请选择 [1-4]: " auth_choice

COOKIE_OPT=""
case $auth_choice in
    1)
        if [ -f "$SAVE_DIR/cookies.txt" ]; then
            info "找到 cookies.txt 文件"
        else
            warn "未找到 cookies.txt"
            read -p "请将 cookies.txt 放入 $SAVE_DIR 后按回车继续..."
        fi
        COOKIE_OPT="--cookies cookies.txt"
        info "✓ 将使用 cookies.txt"
        ;;
    2)
        COOKIE_OPT="--cookies-from-browser firefox"
        info "✓ 将使用 Firefox Cookie"
        ;;
    3)
        COOKIE_OPT="--cookies-from-browser chrome"
        info "✓ 将使用 Chrome Cookie"
        # 再次确认 secretstorage 已安装
        install_pip_package "secretstorage" "secretstorage"
        ;;
    4)
        COOKIE_OPT=""
        warn "将跳过认证，部分视频可能无法下载"
        ;;
esac

# ============================================
# 第七步：下载选项配置
# ============================================
step "6/7 配置下载选项"

# 下载封面
read -p "是否下载并嵌入封面图片？(y/n): " get_cover
if [[ "$get_cover" =~ ^[Yy]$ ]]; then
    COVER_OPTS="--embed-thumbnail --write-thumbnail --convert-thumbnails jpg"
    info "✓ 将下载封面并转换为 JPG"
else
    COVER_OPTS=""
fi

# 下载字幕
read -p "是否下载中英文字幕并转换为 SRT？(y/n): " get_sub
if [[ "$get_sub" =~ ^[Yy]$ ]]; then
    SUB_OPTS="--write-subs --sub-langs zh-Hans,en --write-auto-subs --embed-subs"
    CONVERT_SUB=true
    info "✓ 将下载中英文字幕并嵌入视频"
else
    SUB_OPTS=""
    CONVERT_SUB=false
fi

# ============================================
# 第八步：输入链接并开始下载
# ============================================
step "7/7 输入链接并开始下载"
echo -e "${YELLOW}支持：单个视频 / 播放列表 / 频道${NC}"
read -p "👉 请输入链接: " video_url

if [ -z "$video_url" ]; then
    error "未输入链接！"
    exit 1
fi

echo ""
info "开始下载..."
info "保存位置: $SAVE_DIR"
echo ""

# 执行下载命令
$YT_DLP_CMD \
    $COOKIE_OPT \
    --no-check-certificates \
    --format "bestvideo[ext=mp4]+bestaudio[ext=m4a]/best[ext=mp4]/best" \
    --merge-output-format mp4 \
    $SUB_OPTS \
    $COVER_OPTS \
    --embed-metadata \
    --sleep-interval 10 \
    --retries 20 \
    -o "%(title)s.%(ext)s" \
    "$video_url"

# 检查下载结果
if [ $? -ne 0 ]; then
    error "下载失败！"
    exit 1
fi

# ============================================
# 后处理：转换 VTT 字幕为 SRT
# ============================================
if [ "$CONVERT_SUB" = true ]; then
    echo ""
    info "正在转换字幕格式 (VTT → SRT)..."
    
    converted=0
    for vtt_file in *.vtt; do
        if [ -f "$vtt_file" ]; then
            srt_file="${vtt_file%.vtt}.srt"
            ffmpeg -i "$vtt_file" "$srt_file" -loglevel quiet 2>/dev/null
            if [ $? -eq 0 ]; then
                echo -e "${GREEN}✓ 已转换:${NC} $vtt_file → $srt_file"
                rm -f "$vtt_file"
                ((converted++))
            else
                echo -e "${RED}✗ 转换失败:${NC} $vtt_file"
            fi
        fi
    done
    
    if [ $converted -eq 0 ]; then
        echo "未找到 VTT 字幕文件"
    else
        info "共转换了 $converted 个字幕文件"
    fi
fi

# ============================================
# 完成
# ============================================
echo ""
echo -e "${GREEN}========================================${NC}"
echo -e "${GREEN}下载完成！${NC}"
echo -e "${GREEN}文件保存在: $SAVE_DIR${NC}"
echo -e "${GREEN}========================================${NC}"

# 列出下载的文件
ls -lh "$SAVE_DIR" | grep -E "\.(mp4|jpg|srt)$" | head -10
